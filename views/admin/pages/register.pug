extends ../layouts/account.pug

block main
  .form-account
    h2.inner-title Đăng ký
    p.inner-desc Tạo một tài khoản để tiếp tục
    
    form.inner-form#register-form
      .inner-group
        label(
          class="inner-label"
          for="fullName"
        ) Họ tên
        input(
          type="text"
          name="fullName"
          id="fullName"
          placeholder="Ví dụ: Lê Văn A"
          class="inner-control"
        )
      .inner-group
        label(
          class="inner-label"
          for="email"
        ) Email
        input(
          type="email"
          name="email"
          id="email"
          placeholder="Ví dụ: levana@gmail.com"
          class="inner-control"
        )
      .inner-group
        label(class="inner-label" for="password") Mật khẩu
        .inner-password-wrapper
          input(
            type="password"
            name="password"
            id="password"
            class="inner-control"
            autocomplete="new-password"
          )
          button.inner-toggle-password(
            type="button"
            data-target="password"
            aria-label="Hiện mật khẩu"
            aria-pressed="false"
          )
            i.fa-solid.fa-eye
            i.fa-solid.fa-eye-slash
          
      .inner-group
        label(class="inner-label" for="passwordConfirm") Xác nhận mật khẩu
        .inner-password-wrapper
          input(
            type="password"
            name="passwordConfirm"
            id="passwordConfirm"
            class="inner-control"
            autocomplete="new-password"
          )
          button.inner-toggle-password(
            type="button"
            data-target="passwordConfirm"
            aria-label="Hiện xác nhận mật khẩu"
            aria-pressed="false"
          )
            i.fa-solid.fa-eye
            i.fa-solid.fa-eye-slash
      .inner-meta
        .inner-confirm
          input(
            type="checkbox"
            name="agree"
            id="agree"
            class="inner-check"
          )
          label(
            class="inner-label"
            for="agree"
          ) Tôi chấp nhận các điều khoản và điều kiện
      button(class="inner-button") Đăng Ký
    
    .inner-more
      span Bạn đã có tài khoản?
      a(href=`/${pathAdmin}/account/login`) Đăng nhập