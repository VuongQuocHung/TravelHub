extends ../layouts/default.pug

block main
  h1.box-title #{pageTitle}

  //- Section 4
  .section-4
    .inner-wrap
      .inner-item.inner-label
        <i class="fa-solid fa-filter"></i> Bộ lọc
      .inner-item
        select(filter="status")
          option(value="") Trạng thái
          option(value="active") Hoạt động
          option(value="inactive") Tạm dừng
      .inner-item
        select(filter="createdBy")
          option(value="") Người tạo
          each item in accountAdminList
            if item.fullName
              option(value=item.id) #{item.fullName}

      .inner-item.inner-date
        input(type="date" filter="fromDate")
        span -
        input(type="date" filter="toDate")
      .inner-item
        select
          option(value="") Danh mục
          option(value="") Danh mục 1
          option(value="") Danh mục 2
      .inner-item
        select
          option(value="") Mức giá
          option(value="") Dưới 2tr
          option(value="") 2tr đến 4tr
          option(value="") 4tr đến 8tr
          option(value="") Trên 8tr
      .inner-item.inner-reset(filter-reset)
        <i class="fa-solid fa-rotate-left"></i> Xóa bộ lọc
  //- End Section 4

  //- Section 5
  .section-5
    .inner-wrap
      .inner-change-status(change-multi data-api = `/${pathAdmin}/tour/change-multi`)
        .inner-item
          select()
            option(value="") -- Hành động --
            option(value="active") Hoạt động
            option(value="inactive") Dừng hoạt động
            option(value="delete") Xóa
        .inner-item   
          button Áp dụng
      .inner-search
        <i class="fa-solid fa-magnifying-glass"></i>
        input(type="text" placeholder="Tìm kiếm" search)
      .inner-button-create
        a(href=`/${pathAdmin}/tour/create`)  + Tạo mới
      .inner-button-trash
        a(href=`/${pathAdmin}/tour/trash`) Thùng rác
  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th(class="inner-center")
              input(type="checkbox" class="inner-check" check-all)
            th Tên tour
            th Ảnh đại diện
            th Giá
            th Còn lại
            th(class="inner-center") Vị trí
            th(class="inner-center") Trạng thái
            th Tạo bởi
            th Cập nhật bởi
            th Hành động
        tbody
          if(tourList.length > 0)
            each item in tourList
              tr
                td(class="inner-center")
                  input(type="checkbox" class="inner-check" check-item=item.id)
                td #{item.name}
                td
                  img(src=item.avatar class="inner-avatar")
                td
                  div NL: #{item.priceNewAdult.toLocaleString("vi-VN")}đ
                  div TE: #{item.priceNewChildren.toLocaleString("vi-VN")}đ
                  div EB: #{item.priceNewBaby.toLocaleString("vi-VN")}đ
                td
                  div NL: #{item.stockAdult}
                  div TE: #{item.stockChildren}
                  div EB: #{item.stockBaby}
                td(class="inner-center") #{item.position}
                td(class="inner-center")
                  if(item.status == 'active')
                    .badge.badge-green Hoạt động
                  else if(item.status == 'inactive')
                    .badge.badge-red Tạm dừng
                td
                  div #{item.createByName}
                  div.inner-time #{item.createAtFormat}
                td
                  div #{item.updateByName}
                  div.inner-time #{item.updateAtFormat}
                td
                  .inner-buttons
                    a(href=`/${pathAdmin}/tour/edit/${item.id}` class="inner-edit") <i class="fa-regular fa-pen-to-square"></i>
                    button(
                      class="inner-delete" 
                    button-delete 
                    data-api=`/${pathAdmin}/tour/delete/${item.id}`
                    ) <i class="fa-regular fa-trash-can"></i>
          else 
            tr  
              td(colspan="10") Không có dữ liệu
  //- End Section 6

  //- Section 7
  .section-7
    span(class="inner-label") 
      | Hiển thị #{paginationData.skip + 1}
      | - #{paginationData.skip + tourList.length}
      | của #{paginationData.totalRecord}
    select(class="inner-pagination" pagination)
      - for(let i = 1; i <= paginationData.totalPage; i++)
        option(value=i) Trang #{i}
  //- End Section 7