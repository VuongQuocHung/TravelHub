extends ../layouts/default.pug
include ../mixins/filter.pug 
include ../mixins/change-multi.pug 
include ../mixins/search.pug 
include ../mixins/buttons.pug 

block main
  h1.box-title #{pageTitle}
  //- Section 5
  .section-5
    .inner-wrap
      +change-multi-status(`/${pathAdmin}/setting/role/change-multi`, [
        { value: 'undo', label: 'Khôi phục' },
        { value: 'delete-eternal', label: 'Xóa vĩnh viễn' },
      ])
      +search()

  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th(class="inner-center")
              input(type="checkbox" class="inner-check" check-all)
            th Tên nhóm quyền
            th Mô tả ngắn
            th Hành động
        tbody
          each role in roleList
            tr
              td(class="inner-center")
                input(type="checkbox" class="inner-check" check-item=role.id)
              td #{role.name}
              td #{role.description}
              td
                .inner-buttons
                  button(
                    class="inner-undo"
                    button-delete 
                    data-api=`/${pathAdmin}/setting/role/undo/${role.id}`
                  ) <i class="fa-solid fa-rotate-left"></i>

                  button(
                    class="inner-delete"
                    button-delete 
                    data-api=`/${pathAdmin}/setting/role/delete-eternal/${role.id}`
                  ) <i class="fa-regular fa-trash-can"></i>
    .inner-back
      a(href=`/${pathAdmin}/setting/role/list`) Quay lại danh sách
                  
  //- End Section 6