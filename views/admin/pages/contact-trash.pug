extends ../layouts/default.pug
include ../mixins/filter.pug 
include ../mixins/change-multi.pug 
include ../mixins/search.pug 
include ../mixins/buttons.pug 
include ../mixins/trash.pug
include ../mixins/pagination.pug 
include ../mixins/back.pug 

block main
  h1.box-title Các thông tin liên hệ đã xóa

  //- Section 5
  .section-5
    .inner-wrap
      +change-multi-status(`/${pathAdmin}/contact/change-multi`, [
        { value: 'undo', label: 'Khôi phục' },
        { value: 'delete-eternal', label: 'Xóa vĩnh viễn' },
      ])
      
      +search()

  //- End Section 5

  //- Section 6
  .section-6
    .table-2
      table
        thead
          tr
            th(class="inner-center")
              input(type="checkbox" class="inner-check" check-all)
            th Email
            th Ngày tạo
            th(class="inner-center") Hành động
        tbody
          each item in contactList
            tr
              td(class="inner-center")
                input(type="checkbox" class="inner-check" check-item=item.id)
                td #{item.email}
                td #{item.createdAtFormat}
              td(class="inner-center")
                .inner-buttons
                  +button-delete(`/${pathAdmin}/contact/delete/${item.id}`)
      
      .inner-back 
        +back(`/${pathAdmin}/contact/list`)    
  //- End Section 6

  //- Section 7
  .section-7
    span(class="inner-label") Hiển thị 1 - 9 của 78
    select(class="inner-pagination")
      option Trang 1
      option Trang 2
      option Trang 3
  //- End Section 7